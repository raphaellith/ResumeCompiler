{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "dialog:allow-open",
    "fs:allow-home-read-recursive",
    "fs:allow-home-write-recursive"
  ]
}
